# ================================
# AVTO-XABARCHI BOT — .env.example
# ================================

# --- Telegram Bot ---
BOT_TOKEN=your_bot_token_here          # @BotFather dan olingan token
ADMIN_ID=123456789                     # Sizning Telegram user ID

# --- Telegram API (userbot) ---
API_ID=12345678                        # https://my.telegram.org
API_HASH=your_api_hash_here

# --- MongoDB ---
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/avto_xabarchi?retryWrites=true&w=majority

# --- Storage kanal ---
STORAGE_CHANNEL_USERNAME=@your_storage_channel

# --- Server ---
PORT=3000
WEBHOOK_DOMAIN=https://your-app.onrender.com   # Render URL (polling uchun bo'sh qoldiring)

# --- Session fayllar ---
SESSIONS_DIR=sessions

# --- Avtomatik yuborish sozlamalari ---
MIN_INTERVAL=60        # Minimum interval (soniya)
MAX_INTERVAL=300       # Maximum interval (soniya)
RANDOM_MESSAGES=true   # Tasodifiy tartibda yuborish (true/false)
